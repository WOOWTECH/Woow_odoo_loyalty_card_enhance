<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="woow_loyalty_consign.ConsignCardPopup">
        <Dialog title="title" size="'lg'">
            <div class="consign-card-popup">
                <div class="mb-3 text-muted fs-5">
                    <t t-esc="subtitle"/>
                </div>
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>品項</th>
                            <th class="text-center">可用數量</th>
                            <th class="text-center">核銷數量</th>
                            <th class="text-end">到期日</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.lines" t-as="line" t-key="line.id">
                            <tr>
                                <td>
                                    <span t-esc="line.product_name"/>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-info" t-esc="line.qty_remaining"/>
                                </td>
                                <td class="text-center">
                                    <div class="d-inline-flex align-items-center">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                t-on-click="() => this.decrement(line)">
                                            <i class="fa fa-minus"/>
                                        </button>
                                        <input type="number"
                                               class="form-control form-control-sm text-center mx-1"
                                               style="width: 60px;"
                                               t-att-value="line.qty_to_redeem"
                                               t-att-max="line.qty_remaining"
                                               min="0"
                                               t-on-change="(ev) => this.setQty(line, ev)"/>
                                        <button class="btn btn-sm btn-outline-secondary"
                                                t-on-click="() => this.increment(line)">
                                            <i class="fa fa-plus"/>
                                        </button>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <span t-if="line.date_expiry" t-esc="line.date_expiry"/>
                                    <span t-else="" class="text-muted">--</span>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary btn-lg"
                        t-att-disabled="!hasSelection"
                        t-on-click="confirm">
                    <i class="fa fa-check me-1"/>確認核銷
                </button>
                <button class="btn btn-secondary btn-lg" t-on-click="props.close">
                    取消
                </button>
            </t>
        </Dialog>
    </t>
</templates>
