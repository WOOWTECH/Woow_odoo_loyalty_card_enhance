<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 銷售訂單表單繼承 -->
    <record id="sale_order_view_form_consign" model="ir.ui.view">
        <field name="name">sale.order.form.consign</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <!-- 在 button_box 中加入寄品按鈕 -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_consign_lines"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-archive"
                        invisible="consign_line_count == 0">
                    <field name="consign_line_count" widget="statinfo"
                           string="寄品"/>
                </button>
            </xpath>

            <!-- 在訂單行清單加入 is_consigned -->
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_qty']" position="after">
                <field name="is_consigned" column_invisible="True"/>
            </xpath>
        </field>
    </record>

</odoo>
