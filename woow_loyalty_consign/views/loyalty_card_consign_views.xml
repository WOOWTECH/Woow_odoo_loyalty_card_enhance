<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 寄品卡表單（繼承 loyalty.card form） -->
    <record id="loyalty_card_consign_view_form" model="ir.ui.view">
        <field name="name">loyalty.card.form.consign</field>
        <field name="model">loyalty.card</field>
        <field name="inherit_id" ref="loyalty.loyalty_card_view_form"/>
        <field name="arch" type="xml">
            <!-- 在 sheet 前加入 header -->
            <xpath expr="//sheet" position="before">
                <header invisible="not is_consign">
                    <button name="action_send_consign_card"
                            type="object"
                            string="重寄通知"
                            class="btn-secondary"/>
                    <button name="action_open_redeem_wizard"
                            type="object"
                            string="核銷"
                            class="btn-primary"/>
                </header>
            </xpath>

            <!-- 在 partner_id 之後加入寄品卡欄位 -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_consign" invisible="1"/>
                <field name="consign_card_type" invisible="not is_consign"/>
                <field name="consign_expiry_date" invisible="not is_consign"/>
            </xpath>

            <!-- 原生 loyalty.card form 已有 <chatter/>，不需重複加入 -->

            <!-- 在 notebook 中加入寄品頁籤 -->
            <xpath expr="//notebook" position="inside">
                <page string="寄品明細" name="consign_lines"
                      invisible="not is_consign">
                    <group>
                        <group>
                            <field name="consign_total_remaining_qty"/>
                            <field name="consign_active_lines"/>
                        </group>
                        <group>
                            <field name="consign_total_remaining_value"/>
                        </group>
                    </group>
                    <field name="consign_line_ids" nolabel="1">
                        <list decoration-muted="state == 'depleted'"
                              decoration-danger="state == 'expired'">
                            <field name="product_desc"/>
                            <field name="product_id"/>
                            <field name="lot_id" optional="hide"/>
                            <field name="storage_note" optional="hide"/>
                            <field name="qty_deposited"/>
                            <field name="qty_redeemed"/>
                            <field name="qty_remaining"/>
                            <field name="unit_price"/>
                            <field name="amount_remaining"/>
                            <field name="date_deposited"/>
                            <field name="date_expiry"/>
                            <field name="state"/>
                        </list>
                    </field>
                </page>
                <page string="核銷紀錄" name="consign_redemptions"
                      invisible="not is_consign">
                    <field name="consign_redemption_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="date_redemption"/>
                            <field name="staff_user_id"/>
                            <field name="total_redeemed_value"/>
                            <field name="state"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- 寄品卡清單 -->
    <record id="loyalty_card_consign_view_tree" model="ir.ui.view">
        <field name="name">loyalty.card.consign.list</field>
        <field name="model">loyalty.card</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="code"/>
                <field name="partner_id"/>
                <field name="consign_card_type"/>
                <field name="consign_total_remaining_qty" string="剩餘數量"/>
                <field name="consign_total_remaining_value" string="剩餘金額"/>
                <field name="consign_active_lines" string="有效品項"/>
                <field name="create_date" string="建立日期"/>
                <field name="program_id"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- 寄品卡搜尋 -->
    <record id="loyalty_card_consign_view_search" model="ir.ui.view">
        <field name="name">loyalty.card.consign.search</field>
        <field name="model">loyalty.card</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="program_id"/>
                <filter name="filter_active" string="有效" domain="[('active', '=', True)]"/>
                <filter name="filter_has_remaining" string="有剩餘"
                        domain="[('consign_total_remaining_qty', '>', 0)]"/>
                <separator/>
                <filter name="group_partner" string="依客戶" context="{'group_by': 'partner_id'}"/>
                <filter name="group_program" string="依方案" context="{'group_by': 'program_id'}"/>
                <filter name="group_card_type" string="依類型"
                        context="{'group_by': 'consign_card_type'}"/>
            </search>
        </field>
    </record>

    <!-- 寄品卡動作 -->
    <record id="loyalty_card_consign_action" model="ir.actions.act_window">
        <field name="name">寄品卡</field>
        <field name="res_model">loyalty.card</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_consign', '=', True)]</field>
        <field name="search_view_id" ref="loyalty_card_consign_view_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                目前沒有寄品卡
            </p>
            <p>
                寄品卡會在銷售訂單確認時自動建立。
            </p>
        </field>
    </record>
    <record id="loyalty_card_consign_action_tree" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="loyalty_card_consign_view_tree"/>
        <field name="act_window_id" ref="loyalty_card_consign_action"/>
    </record>

</odoo>
