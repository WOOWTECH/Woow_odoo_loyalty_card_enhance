<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 核銷精靈表單 -->
    <record id="consign_redeem_wizard_view_form" model="ir.ui.view">
        <field name="name">consign.redeem.wizard.form</field>
        <field name="model">consign.redeem.wizard</field>
        <field name="arch" type="xml">
            <form string="寄品核銷">
                <group>
                    <group>
                        <field name="card_id"/>
                        <field name="partner_id"/>
                        <field name="date_redemption"/>
                    </group>
                    <group>
                        <field name="staff_user_id"/>
                    </group>
                </group>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom">
                        <field name="selected"/>
                        <field name="consign_line_id" readonly="1" force_save="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="product_desc" readonly="1"/>
                        <field name="qty_available" readonly="1"/>
                        <field name="qty_to_redeem"/>
                        <field name="note"/>
                    </list>
                </field>
                <group>
                    <field name="service_note" placeholder="施打劑量、操作師、備註..."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object"
                            string="確認核銷" class="btn-primary"/>
                    <button string="取消" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
