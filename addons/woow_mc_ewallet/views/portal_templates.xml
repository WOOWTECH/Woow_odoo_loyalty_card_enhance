<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hub Card: 電子錢包 -->
    <template id="mc_hub_ewallet_card"
              inherit_id="woow_member_center.portal_member_center_hub">
        <xpath expr="//div[@id='mc_hub_grid']" position="inside">
            <t t-if="show_ewallet">
                <a href="/my/member-center/ewallet" class="mc-hub-card" data-mc-order="10">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_mc_ewallet/static/src/img/ewallet.svg" alt="電子錢包"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">電子錢包</div>
                        <div class="mc-hub-card-text">查看餘額與交易紀錄</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-primary">
                            <t t-out="'{:,.0f}'.format(ewallet_balance)"/>
                            <t t-out="ewallet_point_name"/>
                        </span>
                    </div>
                </a>
            </t>
        </xpath>
    </template>

    <!-- Breadcrumbs -->
    <template id="portal_breadcrumb_ewallet"
              inherit_id="portal.portal_breadcrumbs"
              priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name in ('mc_ewallet', 'mc_ewallet_detail')" class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_ewallet'"
                class="breadcrumb-item active">電子錢包</li>
            <li t-if="page_name == 'mc_ewallet_detail'" class="breadcrumb-item">
                <a href="/my/member-center/ewallet">電子錢包</a>
            </li>
            <li t-if="page_name == 'mc_ewallet_detail'"
                class="breadcrumb-item active">
                <t t-out="card.program_id.name"/>
            </li>
        </xpath>
    </template>

    <!-- 電子錢包列表 -->
    <template id="portal_mc_ewallet" name="Portal: 電子錢包">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">電子錢包</t>
            </t>

            <t t-if="not cards">
                <div class="alert alert-info mt-3" role="alert">
                    目前沒有電子錢包。
                </div>
            </t>

            <t t-if="cards">
                <!-- 總餘額 -->
                <div class="mc-balance-hero mt-4">
                    <div class="mc-balance-hero-label">總餘額</div>
                    <div class="mc-balance-hero-amount">
                        <t t-out="'{:,.0f}'.format(total_balance)"/>
                        <span class="mc-balance-hero-unit">
                            <t t-out="point_name"/>
                        </span>
                    </div>
                </div>

                <!-- 各錢包明細 -->
                <div class="table-responsive mt-4">
                    <table class="table table-hover o_portal_my_doc_table">
                        <thead>
                            <tr class="active">
                                <th>方案</th>
                                <th>卡號</th>
                                <th class="text-end">餘額</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="cards" t-as="card">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/member-center/ewallet/#{card.id}">
                                            <t t-out="card.program_id.name"/>
                                        </a>
                                    </td>
                                    <td><t t-out="card.code"/></td>
                                    <td class="text-end">
                                        <strong>
                                            <t t-out="'{:,.0f}'.format(card.points)"/>
                                            <t t-out="card.point_name"/>
                                        </strong>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- 電子錢包明細 -->
    <template id="portal_mc_ewallet_detail" name="Portal: 電子錢包明細">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col-12 col-md-6">
                            <h3 class="mb-0">
                                <t t-out="card.program_id.name"/>
                            </h3>
                        </div>
                        <div class="col-12 col-md-6 text-md-end">
                            <span class="badge bg-primary fs-5">
                                <t t-out="'{:,.0f}'.format(card.points)"/>
                                <t t-out="card.point_name"/>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>卡號：</strong>
                            <t t-out="card.code"/>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>建立日期：</strong>
                            <t t-out="card.create_date" t-options="{'widget': 'date'}"/>
                        </div>
                    </div>
                    <t t-if="card.expiration_date">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <strong>到期日：</strong>
                                <t t-out="card.expiration_date" t-options="{'widget': 'date'}"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <!-- 交易紀錄 -->
            <t t-call="woow_member_center.portal_loyalty_history_table"/>

            <!-- chatter -->
            <hr/>
            <div id="ewallet_communication" class="mt-4">
                <h3>溝通紀錄</h3>
                <t t-call="portal.message_thread"/>
            </div>
        </t>
    </template>

</odoo>
