<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 寄品明細表單 -->
    <record id="loyalty_consign_line_view_form" model="ir.ui.view">
        <field name="name">loyalty.consign.line.form</field>
        <field name="model">loyalty.consign.line</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_cancel" type="object" string="取消"
                            invisible="state != 'active'"
                            confirm="確定要取消此品項嗎？取消後無法恢復。"
                            groups="sales_team.group_sale_manager"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,depleted"/>
                </header>
                <sheet>
                    <group>
                        <group string="品項資訊">
                            <field name="card_id"/>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="product_desc"/>
                            <field name="lot_id"/>
                            <field name="storage_note"/>
                        </group>
                        <group string="數量與金額">
                            <field name="qty_deposited"/>
                            <field name="qty_redeemed"/>
                            <field name="qty_remaining"/>
                            <field name="unit_price"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount_deposited"/>
                            <field name="amount_remaining"/>
                        </group>
                    </group>
                    <group>
                        <group string="日期">
                            <field name="date_deposited"/>
                        </group>
                        <group string="來源">
                            <field name="sale_line_id"/>
                            <field name="sale_order_id"/>
                            <field name="program_id"/>
                        </group>
                    </group>
                    <notebook invisible="not id">
                        <page string="核銷紀錄" name="redemption_lines">
                            <field name="redemption_line_ids" nolabel="1">
                                <list>
                                    <field name="redemption_id"/>
                                    <field name="qty_redeemed"/>
                                    <field name="subtotal"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 寄品明細清單 -->
    <record id="loyalty_consign_line_view_tree" model="ir.ui.view">
        <field name="name">loyalty.consign.line.list</field>
        <field name="model">loyalty.consign.line</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'depleted'">
                <field name="card_id"/>
                <field name="partner_id"/>
                <field name="product_desc"/>
                <field name="product_id"/>
                <field name="lot_id" optional="hide"/>
                <field name="storage_note" optional="hide"/>
                <field name="qty_deposited"/>
                <field name="qty_redeemed"/>
                <field name="qty_remaining"/>
                <field name="unit_price" optional="hide"/>
                <field name="amount_remaining"/>
                <field name="date_deposited"/>
                <field name="sale_order_id" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- 寄品明細搜尋 -->
    <record id="loyalty_consign_line_view_search" model="ir.ui.view">
        <field name="name">loyalty.consign.line.search</field>
        <field name="model">loyalty.consign.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_desc"/>
                <field name="product_id"/>
                <field name="partner_id"/>
                <field name="card_id"/>
                <filter name="filter_active" string="有效"
                        domain="[('state', '=', 'active')]"/>
                <filter name="filter_depleted" string="已用完"
                        domain="[('state', '=', 'depleted')]"/>
                <separator/>
                <filter name="group_partner" string="依客戶"
                        context="{'group_by': 'partner_id'}"/>
                <filter name="group_product" string="依品項"
                        context="{'group_by': 'product_id'}"/>
                <filter name="group_card" string="依卡片"
                        context="{'group_by': 'card_id'}"/>
            </search>
        </field>
    </record>

    <!-- 寄品明細動作 -->
    <record id="loyalty_consign_line_action" model="ir.actions.act_window">
        <field name="name">寄品明細</field>
        <field name="res_model">loyalty.consign.line</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                目前沒有寄品明細
            </p>
        </field>
    </record>

</odoo>
