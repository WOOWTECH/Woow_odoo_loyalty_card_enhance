<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal: 只能看到自己卡片的寄品明細 -->
    <record id="consign_line_portal_rule" model="ir.rule">
        <field name="name">Portal: own consign lines</field>
        <field name="model_id" ref="model_loyalty_consign_line"/>
        <field name="domain_force">[('card_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: 只能看到自己卡片的核銷紀錄 -->
    <record id="consign_redemption_portal_rule" model="ir.rule">
        <field name="name">Portal: own consign redemptions</field>
        <field name="model_id" ref="model_loyalty_consign_redemption"/>
        <field name="domain_force">[('card_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Portal: 只能看到自己的核銷明細 -->
    <record id="consign_redemption_line_portal_rule" model="ir.rule">
        <field name="name">Portal: own consign redemption lines</field>
        <field name="model_id" ref="model_loyalty_consign_redemption_line"/>
        <field name="domain_force">[('redemption_id.card_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
