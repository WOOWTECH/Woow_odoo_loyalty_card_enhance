<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hub Card: 優惠券 -->
    <template id="mc_hub_coupon_card"
              inherit_id="woow_member_center.portal_member_center_hub">
        <xpath expr="//div[@id='mc_hub_grid']" position="inside">
            <t t-if="show_coupon">
                <a href="/my/member-center/coupons" class="mc-hub-card" data-mc-order="40">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_mc_coupon/static/src/img/coupon.svg" alt="優惠券"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">優惠券</div>
                        <div class="mc-hub-card-text">查看可用優惠券</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-warning text-dark">
                            <t t-out="coupon_count"/> 張
                        </span>
                    </div>
                </a>
            </t>
        </xpath>
    </template>

    <!-- Breadcrumbs -->
    <template id="portal_breadcrumb_coupon"
              inherit_id="portal.portal_breadcrumbs"
              priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name in ('mc_coupons', 'mc_coupon_detail')"
                class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_coupons'"
                class="breadcrumb-item active">優惠券</li>
            <li t-if="page_name == 'mc_coupon_detail'" class="breadcrumb-item">
                <a href="/my/member-center/coupons">優惠券</a>
            </li>
            <li t-if="page_name == 'mc_coupon_detail'"
                class="breadcrumb-item active">
                <t t-out="card.code"/>
            </li>
        </xpath>
    </template>

    <!-- 優惠券列表 -->
    <template id="portal_mc_coupon_list" name="Portal: 優惠券列表">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">優惠券</t>
            </t>

            <t t-if="not cards">
                <div class="alert alert-info mt-3" role="alert">
                    目前沒有可用的優惠券。
                </div>
            </t>

            <t t-if="cards">
                <div class="table-responsive mt-3">
                    <table class="table table-hover o_portal_my_doc_table">
                        <thead>
                            <tr class="active">
                                <th>方案</th>
                                <th>優惠碼</th>
                                <th class="text-center">說明</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="cards" t-as="card">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/member-center/coupons/#{card.id}">
                                            <t t-out="card.program_id.name"/>
                                        </a>
                                    </td>
                                    <td>
                                        <code><t t-out="card.code"/></code>
                                    </td>
                                    <td class="text-center">
                                        <t t-if="card.program_id.reward_ids">
                                            <t t-out="card.program_id.reward_ids[:1].description"/>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- 優惠券明細 -->
    <template id="portal_mc_coupon_detail" name="Portal: 優惠券明細">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col-12 col-md-6">
                            <h3 class="mb-0">
                                <t t-out="card.program_id.name"/>
                            </h3>
                        </div>
                        <div class="col-12 col-md-6 text-md-end">
                            <span class="badge bg-warning text-dark fs-5">
                                <t t-out="card.code"/>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>優惠碼：</strong>
                            <code class="fs-5"><t t-out="card.code"/></code>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>建立日期：</strong>
                            <t t-out="card.create_date" t-options="{'widget': 'date'}"/>
                        </div>
                    </div>
                    <t t-if="card.program_id.date_from or card.program_id.date_to">
                        <div class="row">
                            <div class="col-md-6 mb-2" t-if="card.program_id.date_from">
                                <strong>有效開始：</strong>
                                <t t-out="card.program_id.date_from"/>
                            </div>
                            <div class="col-md-6 mb-2" t-if="card.program_id.date_to">
                                <strong>有效結束：</strong>
                                <t t-out="card.program_id.date_to"/>
                            </div>
                        </div>
                    </t>

                    <!-- 優惠內容 -->
                    <t t-if="card.program_id.reward_ids">
                        <h5 class="mt-3">優惠內容</h5>
                        <t t-foreach="card.program_id.reward_ids" t-as="reward">
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <t t-out="reward.description"/>
                                </div>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

            <!-- 交易紀錄 -->
            <t t-call="woow_member_center.portal_loyalty_history_table"/>

            <!-- chatter -->
            <hr/>
            <div id="coupon_communication" class="mt-4">
                <h3>溝通紀錄</h3>
                <t t-call="portal.message_thread"/>
            </div>
        </t>
    </template>

</odoo>
