<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Home: 加入「會員中心」入口卡片                          -->
    <!-- ============================================================ -->
    <template id="portal_my_home_member_center"
              name="Portal: 會員中心入口"
              inherit_id="portal.portal_my_home"
              priority="25">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/woow_member_center/static/src/img/member-center.svg'"/>
                <t t-set="title">會員中心</t>
                <t t-set="url" t-value="'/my/member-center'"/>
                <t t-set="text">我的會員服務</t>
                <t t-set="placeholder_count" t-value="'member_center_count'"/>
            </t>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Hub Page: 會員中心主頁（空 grid，子模組透過 xpath 注入卡片）    -->
    <!-- ============================================================ -->
    <template id="portal_member_center_hub" name="Portal: 會員中心">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">會員中心</t>
            </t>

            <div class="mc-hub-grid mt-4" id="mc_hub_grid">
                <!-- 子模組透過 xpath position="inside" 注入各自的卡片 -->
            </div>

            <!-- 空狀態提示（當沒有任何子模組安裝或無資料時） -->
            <div class="mc-hub-empty text-center text-muted py-5" id="mc_hub_empty">
                <img src="/woow_member_center/static/src/img/member-center.svg"
                     style="width:64px; opacity:.5;" class="mb-3" alt=""/>
                <p>目前沒有可用的會員功能。</p>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Breadcrumbs (Hub only — 子模組各自加入自己的 breadcrumb)      -->
    <!-- ============================================================ -->
    <template id="portal_breadcrumb_member_center"
              inherit_id="portal.portal_breadcrumbs"
              priority="25">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Hub -->
            <li t-if="page_name == 'member_center'"
                class="breadcrumb-item active">會員中心</li>

            <!-- 交易紀錄歷史頁 -->
            <li t-if="page_name == 'mc_card_history'" class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_card_history'" class="breadcrumb-item">
                <a t-att-href="parent_url"><t t-out="parent_title"/></a>
            </li>
            <li t-if="page_name == 'mc_card_history'" class="breadcrumb-item">
                <a t-att-href="card_url"><t t-out="card.program_id.name"/></a>
            </li>
            <li t-if="page_name == 'mc_card_history'" class="breadcrumb-item active">
                交易紀錄
            </li>
        </xpath>
    </template>

</odoo>
