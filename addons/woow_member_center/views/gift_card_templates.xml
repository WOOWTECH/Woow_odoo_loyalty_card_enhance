<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 禮品卡列表 -->
    <template id="portal_mc_gift_card_list" name="Portal: 禮品卡列表">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">禮品卡</t>
            </t>

            <t t-if="not cards">
                <div class="alert alert-info mt-3" role="alert">
                    目前沒有禮品卡。
                </div>
            </t>

            <t t-if="cards">
                <div class="table-responsive mt-3">
                    <table class="table table-hover o_portal_my_doc_table">
                        <thead>
                            <tr class="active">
                                <th>方案</th>
                                <th>卡號</th>
                                <th class="text-end">餘額</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="cards" t-as="card">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/member-center/gift-cards/#{card.id}">
                                            <t t-out="card.program_id.name"/>
                                        </a>
                                    </td>
                                    <td><t t-out="card.code"/></td>
                                    <td class="text-end">
                                        <strong>
                                            <t t-out="'{:,.0f}'.format(card.points)"/>
                                            <t t-out="card.point_name"/>
                                        </strong>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- 禮品卡明細 -->
    <template id="portal_mc_gift_card_detail" name="Portal: 禮品卡明細">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col-12 col-md-6">
                            <h3 class="mb-0">
                                <t t-out="card.program_id.name"/>
                            </h3>
                        </div>
                        <div class="col-12 col-md-6 text-md-end">
                            <span class="badge bg-info fs-5">
                                <t t-out="'{:,.0f}'.format(card.points)"/>
                                <t t-out="card.point_name"/>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>卡號：</strong>
                            <t t-out="card.code"/>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>建立日期：</strong>
                            <t t-out="card.create_date" t-options="{'widget': 'date'}"/>
                        </div>
                    </div>
                    <t t-if="card.program_id.date_from or card.program_id.date_to">
                        <div class="row">
                            <div class="col-md-6 mb-2" t-if="card.program_id.date_from">
                                <strong>方案開始：</strong>
                                <t t-out="card.program_id.date_from"/>
                            </div>
                            <div class="col-md-6 mb-2" t-if="card.program_id.date_to">
                                <strong>方案結束：</strong>
                                <t t-out="card.program_id.date_to"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <!-- chatter -->
            <hr/>
            <div id="gift_card_communication" class="mt-4">
                <h3>溝通紀錄</h3>
                <t t-call="portal.message_thread"/>
            </div>
        </t>
    </template>

</odoo>
