<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- 共用交易紀錄表格片段（嵌入各卡片明細頁）                       -->
    <!-- ============================================================ -->
    <template id="portal_loyalty_history_table" name="Portal: 交易紀錄表格片段">
        <t t-if="history_lines">
            <div class="card mt-3 mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">交易紀錄</h5>
                    <span class="badge bg-secondary rounded-pill">
                        <t t-out="history_count"/> 筆
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>日期</th>
                                    <th>說明</th>
                                    <th>關聯訂單</th>
                                    <th class="text-end">前餘額</th>
                                    <th class="text-end">增加</th>
                                    <th class="text-end">使用</th>
                                    <th class="text-end">後餘額</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="history_lines" t-as="line">
                                    <tr>
                                        <td>
                                            <t t-out="line.create_date" t-options="{'widget': 'date'}"/>
                                        </td>
                                        <td>
                                            <t t-set="desc" t-value="line.description or ''"/>
                                            <t t-if="desc.startswith('Order ')">
                                                訂單 <t t-out="desc[6:]"/>
                                            </t>
                                            <t t-else="">
                                                <t t-out="desc"/>
                                            </t>
                                        </td>
                                        <td>
                                            <t t-if="line.order_id">
                                                <t t-set="order_portal_url" t-value="line._get_order_portal_url()"/>
                                                <t t-set="order_description" t-value="line._get_order_description()"/>
                                                <a t-if="order_portal_url"
                                                   t-att-href="order_portal_url">
                                                    <t t-out="order_description"/>
                                                </a>
                                                <span t-else="" t-out="order_description"/>
                                            </t>
                                            <span t-else="" class="text-muted">—</span>
                                        </td>
                                        <td class="text-end text-muted">
                                            <t t-out="line.card_id._format_points(line.balance_before)"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-if="line.issued"
                                                  class="text-success fw-bold">
                                                +<t t-out="line.card_id._format_points(line.issued)"/>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <span t-if="line.used"
                                                  class="text-danger fw-bold">
                                                -<t t-out="line.card_id._format_points(line.used)"/>
                                            </span>
                                        </td>
                                        <td class="text-end fw-bold">
                                            <t t-out="line.card_id._format_points(line.balance_after)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- 超過 10 筆時顯示「查看全部」 -->
                <div class="card-footer text-center" t-if="show_history_link">
                    <a t-att-href="history_url">
                        查看全部歷史紀錄 (<t t-out="history_count"/> 筆)
                    </a>
                </div>
            </div>
        </t>
    </template>

</odoo>
