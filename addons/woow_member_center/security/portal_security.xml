<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal: 只能看到自己的會員資格紀錄 -->
    <record id="membership_line_portal_rule" model="ir.rule">
        <field name="name">Portal: own membership lines</field>
        <field name="model_id" ref="membership.model_membership_membership_line"/>
        <field name="domain_force">[('partner', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
