<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal Home: 加入「會員中心」入口卡片                          -->
    <!-- ============================================================ -->
    <template id="portal_my_home_member_center"
              name="Portal: 會員中心入口"
              inherit_id="portal.portal_my_home"
              priority="25">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/woow_member_center/static/src/img/member-center.svg'"/>
                <t t-set="title">會員中心</t>
                <t t-set="url" t-value="'/my/member-center'"/>
                <t t-set="text">電子錢包、集點卡、禮品卡、優惠券、會員資格、寄品卡</t>
                <t t-set="placeholder_count" t-value="'member_center_count'"/>
            </t>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Hub Page: 會員中心主頁（6 張功能卡片）                         -->
    <!-- ============================================================ -->
    <template id="portal_member_center_hub" name="Portal: 會員中心">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">會員中心</t>
            </t>

            <div class="mc-hub-grid mt-4">

                <!-- 電子錢包 -->
                <a href="/my/member-center/ewallet" class="mc-hub-card">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_member_center/static/src/img/ewallet.svg" alt="電子錢包"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">電子錢包</div>
                        <div class="mc-hub-card-text">查看餘額與交易紀錄</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-primary">
                            <t t-out="'{:,.0f}'.format(ewallet_balance)"/>
                            <t t-out="ewallet_point_name"/>
                        </span>
                    </div>
                </a>

                <!-- 集點卡 -->
                <a href="/my/member-center/loyalty" class="mc-hub-card">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_member_center/static/src/img/loyalty.svg" alt="集點卡"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">集點卡</div>
                        <div class="mc-hub-card-text">查看累積點數</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-success">
                            <t t-out="'{:,.0f}'.format(loyalty_points)"/>
                            <t t-out="loyalty_point_name"/>
                        </span>
                    </div>
                </a>

                <!-- 禮品卡 -->
                <a href="/my/member-center/gift-cards" class="mc-hub-card">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_member_center/static/src/img/gift-card.svg" alt="禮品卡"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">禮品卡</div>
                        <div class="mc-hub-card-text">查看禮品卡餘額</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-info">
                            <t t-out="'{:,.0f}'.format(gift_balance)"/>
                            <t t-out="gift_point_name"/>
                        </span>
                    </div>
                </a>

                <!-- 優惠券 -->
                <a href="/my/member-center/coupons" class="mc-hub-card">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_member_center/static/src/img/coupon.svg" alt="優惠券"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">優惠券</div>
                        <div class="mc-hub-card-text">查看可用優惠券</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-warning text-dark">
                            <t t-out="coupon_count"/> 張
                        </span>
                    </div>
                </a>

                <!-- 會員資格 -->
                <a href="/my/member-center/membership" class="mc-hub-card">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_member_center/static/src/img/membership.svg" alt="會員資格"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">會員資格</div>
                        <div class="mc-hub-card-text">查看會員方案與期限</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span t-attf-class="badge rounded-pill #{
                            'bg-success' if membership_state in ('paid', 'free') else
                            'bg-secondary' if membership_state == 'none' else
                            'bg-warning text-dark'
                        }">
                            <t t-out="membership_state_label"/>
                        </span>
                    </div>
                </a>

                <!-- 寄品卡 -->
                <a href="/my/consign-cards" class="mc-hub-card">
                    <div class="mc-hub-card-icon">
                        <img src="/woow_member_center/static/src/img/consign.svg" alt="寄品卡"/>
                    </div>
                    <div class="mc-hub-card-body">
                        <div class="mc-hub-card-title">寄品卡</div>
                        <div class="mc-hub-card-text">查看寄品卡與核銷紀錄</div>
                    </div>
                    <div class="mc-hub-card-metric">
                        <span class="badge rounded-pill bg-secondary">
                            <t t-out="consign_count"/> 張
                        </span>
                    </div>
                </a>

            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Breadcrumbs                                                   -->
    <!-- ============================================================ -->
    <template id="portal_breadcrumb_member_center"
              inherit_id="portal.portal_breadcrumbs"
              priority="25">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Hub -->
            <li t-if="page_name == 'member_center'"
                class="breadcrumb-item active">會員中心</li>

            <!-- eWallet -->
            <li t-if="page_name in ('mc_ewallet', 'mc_ewallet_detail')" class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_ewallet'"
                class="breadcrumb-item active">電子錢包</li>
            <li t-if="page_name == 'mc_ewallet_detail'" class="breadcrumb-item">
                <a href="/my/member-center/ewallet">電子錢包</a>
            </li>
            <li t-if="page_name == 'mc_ewallet_detail'"
                class="breadcrumb-item active">
                <t t-out="card.program_id.name"/>
            </li>

            <!-- Loyalty List -->
            <li t-if="page_name in ('mc_loyalty', 'mc_loyalty_detail')"
                class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_loyalty'"
                class="breadcrumb-item active">集點卡</li>
            <li t-if="page_name == 'mc_loyalty_detail'" class="breadcrumb-item">
                <a href="/my/member-center/loyalty">集點卡</a>
            </li>
            <li t-if="page_name == 'mc_loyalty_detail'"
                class="breadcrumb-item active">
                <t t-out="card.program_id.name"/>
            </li>

            <!-- Gift Card List -->
            <li t-if="page_name in ('mc_gift_cards', 'mc_gift_card_detail')"
                class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_gift_cards'"
                class="breadcrumb-item active">禮品卡</li>
            <li t-if="page_name == 'mc_gift_card_detail'" class="breadcrumb-item">
                <a href="/my/member-center/gift-cards">禮品卡</a>
            </li>
            <li t-if="page_name == 'mc_gift_card_detail'"
                class="breadcrumb-item active">
                <t t-out="card.program_id.name"/>
            </li>

            <!-- Coupon List -->
            <li t-if="page_name in ('mc_coupons', 'mc_coupon_detail')"
                class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_coupons'"
                class="breadcrumb-item active">優惠券</li>
            <li t-if="page_name == 'mc_coupon_detail'" class="breadcrumb-item">
                <a href="/my/member-center/coupons">優惠券</a>
            </li>
            <li t-if="page_name == 'mc_coupon_detail'"
                class="breadcrumb-item active">
                <t t-out="card.code"/>
            </li>

            <!-- Membership -->
            <li t-if="page_name == 'mc_membership'" class="breadcrumb-item">
                <a href="/my/member-center">會員中心</a>
            </li>
            <li t-if="page_name == 'mc_membership'"
                class="breadcrumb-item active">會員資格</li>
        </xpath>
    </template>

</odoo>
